# INFERRA local/staging environment template.
# Copy to .env for local Docker Compose overrides. Do not commit real secrets.

INFERRA_AUTH_ENABLED=false
INFERRA_API_KEY=replace-with-random-api-key
INFERRA_API_KEY_OWNER_ID=api-key
INFERRA_JWT_SECRET=replace-with-random-jwt-secret
INFERRA_CSRF_PROTECTION=false
INFERRA_CSRF_TOKEN=replace-with-random-csrf-token

POSTGRES_USER=inferra
POSTGRES_PASSWORD=replace-with-postgres-password
SQLALCHEMY_DATABASE_URI=postgresql://inferra:replace-with-postgres-password@postgres:5432/inferra

FUSEKI_USER=admin
FUSEKI_PASSWORD=replace-with-fuseki-admin-password

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-grafana-admin-password

# Local Docker Redis is unauthenticated by default.
# Production rehearsal uses secrets/redis_password.txt via docker-compose.prod.yml.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

INFERRA_LLM_ENHANCEMENTS=false
INFERRA_ABDUCTION_ADAPTER=z3
INFERRA_LLM_ABDUCTION_MAX_HYPOTHESES=5

# Preferred multi-provider LLM configuration. The frontend can list these with
# GET /api/v1/llm/providers and pass llm_provider/llm_model to file conversion.
INFERRA_LLM_PROVIDER=nvidia
INFERRA_LLM_MODEL=deepseek-ai/deepseek-v4-pro
MODALRESEARCH_API_KEY=
MODALRESEARCH_API_KEY_FILE=
NVIDIA_API_KEY=
NVIDIA_API_KEY_FILE=

# Generic custom OpenAI-compatible provider override.
INFERRA_LLM_BASE_URL=
INFERRA_LLM_API_KEY=
INFERRA_LLM_API_KEY_FILE=
INFERRA_LLM_API=openai-completions

# Legacy compatibility path.
ZAI_BASE_URL=
ZAI_API_KEY=
ZAI_API_KEY_FILE=
ZAI_MODEL=
LLM_TIMEOUT=30
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=0.1
LLM_CIRCUIT_FAILURE_THRESHOLD=3
LLM_CIRCUIT_RECOVERY_TIMEOUT_SECONDS=30
